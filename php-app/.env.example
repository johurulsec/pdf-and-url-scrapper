ENV=dev
LOCALE=ja-JP
SCHEMA_VERSION=1.0

GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

STRICT_VERBATIM=false
MAX_PAGES=4
INCLUDE_OCR_HINT=true
AUTO_TRANSLATE_ALL_TO_EN=true
OUTPUT_ENGLISH_ONLY=true
PRESERVE_ORIGINAL_JA=false

# Optional. Without this key, translated fields stay as original text.
GOOGLE_TRANSLATE_API_KEY=

# Optional. Without this key, the app falls back to OpenStreetMap Nominatim.
GOOGLE_MAPS_API_KEY=

# Jina Reader: free web-to-text proxy (r.jina.ai) — handles JS pages and many IP-blocked sites.
# Enabled by default. Get a free API key at https://jina.ai for higher rate limits.
JINA_READER_ENABLED=true
JINA_API_KEY=

# Optional PHP-only remote fetch fallback for blocked sites such as Rakumachi.
# Use a scraping API URL template that returns HTML, plain text, Markdown, or JSON.
# Supported placeholders: {url}, {url_raw}, {api_key}
REMOTE_FETCH_URL_TEMPLATE=
REMOTE_FETCH_API_KEY=
REMOTE_FETCH_API_KEY_HEADER=
REMOTE_FETCH_JSON_FIELD=

# Legacy optional browser scraper. Leave disabled for Hostinger/shared PHP.
BROWSER_SCRAPER_URL=
BROWSER_SCRAPER_API_KEY=
PREFER_BROWSER_SCRAPER_FOR_RAKUMACHI=false

# Optional local Playwright fallback. Requires Node.js dependencies on the server:
# npm install
# npm run install:playwright
PLAYWRIGHT_RENDERER_ENABLED=false
PLAYWRIGHT_NODE_BIN=node
PLAYWRIGHT_SCRIPT_PATH=
PLAYWRIGHT_TIMEOUT_MS=45000
